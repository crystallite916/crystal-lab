# ============================================
# Monorepo .gitignore Strategy
# ============================================
# This root .gitignore handles global patterns (Python, IDE, OS, credentials, data)
# Projects should only add their own .gitignore if they have project-specific exceptions
#
# New projects: Only create a project .gitignore if you need to override root patterns

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
.cache/
.mypy_cache/
.pytest_cache/

# ============================================
# Virtual Environments
# ============================================
.venv/
venv/
env/
ENV/
__pypackages__/

# ============================================
# Jupyter Notebooks
# ============================================
.ipynb_checkpoints/
*.nbconvert.ipynb

# ============================================
# IDE & Editors
# ============================================
# VSCode - track workspace settings, ignore user settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/
*.swp
*.swo
*~
.history/

# ============================================
# Operating Systems
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Authentication & Credentials
# ============================================
*-key.json
*_key.json
google-drive-key.json
big-query-key.json
service-account*.json
credentials.json
.token.pickle
token.json

# ============================================
# Logs
# ============================================
*.log

# ============================================
# Data Files (can be large)
# ============================================
*.csv
*.xls
*.xlsx
*.xlsm
*.parquet

# ============================================
# PDF Files
# ============================================
*.pdf

# ============================================
# MCP & Configuration
# ============================================
.mcp.json

# ============================================
# Claude Code
# ============================================
.claude/settings.local.json
